# Shared
SAAR_ENV=development

# API / Render
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
SECRET_KEY=change-me
API_AUTH_TOKEN=
ADMIN_AUTH_TOKEN=
INTERNAL_CALLBACK_TOKEN=change-me-too
BILLING_ENFORCED=false

# Database / Queue
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/saar
REDIS_URL=redis://localhost:6379/0
QUEUE_MODE=celery
WORKFLOW_DIR=workflows

# RunPod
RUNPOD_API_KEY=
RUNPOD_MOCK=false
RUNPOD_DEFAULT_WEBHOOK=
RUNPOD_WAN_T2V_ENDPOINT_ID=
RUNPOD_WAN_I2V_ENDPOINT_ID=
RUNPOD_LTX_PREVIEW_ENDPOINT_ID=
RUNPOD_HUNYUAN_ENDPOINT_ID=
RUNPOD_UPSCALE_ENDPOINT_ID=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=saar-videos
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# Web
NEXT_PUBLIC_API_URL=/api/proxy
SAAR_API_URL=http://localhost:8000
SAAR_API_TOKEN=
SAAR_ADMIN_TOKEN=
SAAR_ADMIN_UI_KEY=
